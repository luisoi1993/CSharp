<Window x:Class="Calculadora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculadora" Height="450" Width="300">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Pantalla -->
        <TextBox x:Name="pantalla"
                 Grid.Row="0"
                 Grid.ColumnSpan="4"
                 FontSize="30"
                 Text="0"
                 HorizontalContentAlignment="Right"
                 VerticalContentAlignment="Center"/>

        <!-- FILA 1 -->
        <Button Grid.Row="1" Grid.Column="0" Content="7" Click="Numero_Click"/>
        <Button Grid.Row="1" Grid.Column="1" Content="8" Click="Numero_Click"/>
        <Button Grid.Row="1" Grid.Column="2" Content="9" Click="Numero_Click"/>
        <Button Grid.Row="1" Grid.Column="3" Content="/" Click="Operacion_Click"/>

        <!-- FILA 2 -->
        <Button Grid.Row="2" Grid.Column="0" Content="4" Click="Numero_Click"/>
        <Button Grid.Row="2" Grid.Column="1" Content="5" Click="Numero_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Content="6" Click="Numero_Click"/>
        <Button Grid.Row="2" Grid.Column="3" Content="*" Click="Operacion_Click"/>

        <!-- FILA 3 -->
        <Button Grid.Row="3" Grid.Column="0" Content="1" Click="Numero_Click"/>
        <Button Grid.Row="3" Grid.Column="1" Content="2" Click="Numero_Click"/>
        <Button Grid.Row="3" Grid.Column="2" Content="3" Click="Numero_Click"/>
        <Button Grid.Row="3" Grid.Column="3" Content="-" Click="Operacion_Click"/>

        <!-- FILA 4 -->
        <Button Grid.Row="4" Grid.Column="0" Content="0" Click="Numero_Click"/>
        <Button Grid.Row="4" Grid.Column="1" Content="C" Click="Limpiar_Click"/>
        <Button Grid.Row="4" Grid.Column="2" Content="=" Click="Igual_Click"/>
        <Button Grid.Row="4" Grid.Column="3" Content="+" Click="Operacion_Click"/>

    </Grid>
</Window>