<Window x:Class="ConexionGestionPedidos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConexionGestionPedidos"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="12*"/>
            <ColumnDefinition Width="13*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Clientes" HorizontalAlignment="Left" Margin="58,38,0,0" VerticalAlignment="Top" FontSize="22"/>
        <ListBox Name="listaClientes" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,98,139,193" MouseDoubleClick="listaClientes_MouseDoubleClick"/>
        <Label Content="Productos" HorizontalAlignment="Left" Margin="305,38,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.188,-3.394" FontSize="22" Grid.ColumnSpan="2"/>
        <ListBox Name="pedidosCliente" Margin="245,98,326,191" Grid.ColumnSpan="2" >

        </ListBox>
        <ListBox Name="todosPedidos" Grid.Column="1" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="95,103,23,65"/>
        <Label Grid.Column="1" Content="Label" HorizontalAlignment="Left" Margin="168,77,0,0" VerticalAlignment="Top"/>
        <Button Content="Borrar" HorizontalAlignment="Left" Margin="138,15,0,0" VerticalAlignment="Top" Height="62" Width="186" Grid.Column="1" Click="Button_Click"/>
        <Button Content="Insertar" HorizontalAlignment="Left" Margin="16,246,0,0" VerticalAlignment="Top" Height="34" Width="144" Click="Button_Click_1"/>
        <Button Content="Borrar" HorizontalAlignment="Left" Margin="22,289,0,0" VerticalAlignment="Top" Height="42" Width="132" RenderTransformOrigin="0.397,-0.779" Click="Button_Click_2" />
        <TextBox Name="insertaCliente" HorizontalAlignment="Left" Margin="28,351,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button Content="Actualizar" HorizontalAlignment="Left" Margin="276,257,0,0" VerticalAlignment="Top" Height="74" Width="167" Grid.ColumnSpan="2" Click="Button_Click_4"/>

    </Grid>
</Window>
