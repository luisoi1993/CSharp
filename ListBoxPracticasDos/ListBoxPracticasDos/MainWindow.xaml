<Window x:Class="ListBoxPractica.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Temperaturas" Height="450" Width="800">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <ListBox Name="listaPoblaciones" HorizontalContentAlignment="Stretch">

            <ListBox.ItemTemplate>

                <DataTemplate>
                    <Grid Margin="2">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                   Text="{Binding Poblacion1}"
                   MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"/>

                        <TextBlock Grid.Column="1"
                   Text="{Binding Temperatura1}"
                   MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"/>

                        <TextBlock Grid.Column="2"
                   Text="{Binding Poblacion2}"
                   MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"/>

                        <TextBlock Grid.Column="3"
                   Text="{Binding Temperatura2}"
                   MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"/>

                        <Grid Grid.Column="4" Height="20" VerticalAlignment="Center">
                            <Rectangle Fill="Orange"
                       Height="20"
                       HorizontalAlignment="Left"
                       Width="{Binding Diferencia}"/>
                        </Grid>

                    </Grid>
                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>

        <Button Grid.Row="1"
                Click="Button_Click"
                Width="120"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            Mostrar selección

        </Button>

    </Grid>

</Window>